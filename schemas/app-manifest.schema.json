{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://schemas.vantadeck.org/v1/app-manifest.schema.json",
  "title":"Vantadeck App Manifest",
  "type":"object",
  "additionalProperties":false,
  "required":["schemaVersion","id","name","category","platforms","executables","launchTemplates"],
  "properties":{
    "schemaVersion":{"const":1},
    "id":{"type":"string","pattern":"^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "name":{"type":"string","minLength":1},
    "category":{"enum":["game-engine","dcc","art","code","version-control","utility"]},
    "platforms":{"type":"array","uniqueItems":true,"items":{"enum":["windows","macos","linux"]}},
    "executables":{"type":"array","minItems":1,"items":{"type":"string","minLength":1}},
    "knownPaths":{"type":"array","items":{"type":"string"}},
    "fileTypes":{"type":"array","items":{"type":"string"}},
    "launchTemplates":{"type":"array","items":{"$ref":"#/$defs/launchTemplate"}}
  },
  "$defs":{"launchTemplate":{"type":"object","additionalProperties":false,"required":["id","name","arguments"],"properties":{"id":{"type":"string"},"name":{"type":"string"},"arguments":{"type":"array","items":{"type":"string"}}}}}
}
